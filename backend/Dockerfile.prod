FROM --platform=linux/amd64 node:20-bookworm-slim

WORKDIR /app

# Install build dependencies
RUN apt-get update && apt-get install -y \
    python3 \
    make \
    g++ \
    && rm -rf /var/lib/apt/lists/*

COPY package*.json ./

RUN npm ci --only=production

COPY . .

ENV NODE_ENV=production
EXPOSE 4000

CMD ["npm", "start"]